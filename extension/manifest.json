{
  "manifest_version": 3,
  "name": "AiKlavuz Günlük AI Asistanı",
  "version": "1.2.0",
  "description": "Günün AI promptu, yeni yapay zeka araçları, güncel haberler, yapay zeka alternatifi bulucu ve anında sayfa özetleyici.",
  "permissions": [
    "activeTab",
    "tabs",
    "contextMenus",
    "scripting"
  ],
  "host_permissions": [
    "https://aiklavuz.com/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
